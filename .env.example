# =====================================================================
# axelnova-templates — example env
# Copy to .env and fill in real values. Never commit .env.
#
# Ports: claim from axelnova-infra/docs/port-allocation.md before using.
# Tools range is 3010-3049 / 8010-8049.
# =====================================================================

# ---- Naming (per-tool) -----------------------------------------------
PROJECT_SLUG=my-tool              # used in container names, e.g. my-tool-web-dev
HOST_PORT_WEB=3010                # claim from infra registry
HOST_PORT_API=8010                # claim from infra registry

# ---- API (Laravel) ---------------------------------------------------
APP_KEY=                          # generate: docker compose run --rm api php artisan key:generate --show
ADMIN_API_TOKEN=                  # any opaque string >= 32 chars (token-only auth)

DB_HOST=mysql                     # hostname inside axelnova-shared network
DB_PORT=3306
DB_DATABASE=my_tool_db
DB_USERNAME=my_tool_user
DB_PASSWORD=my_tool_local_pw

CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

PUPPETEER_URL=http://puppeteer:3000
FRONTEND_INTERNAL_URL=http://web:3000

# ---- Web (Nuxt) ------------------------------------------------------
# Public base — used by the browser. In dev points at host port.
NUXT_PUBLIC_API_BASE=http://localhost:8010
# Internal base — used by SSR fetches running inside the web container.
NUXT_API_BASE_INTERNAL=http://api:8000
